    "test": "turbo run test --filter=mcp-archimate --filter=web",
    "test:coverage": "turbo run test:coverage --filter=mcp-archimate --filter=web"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
